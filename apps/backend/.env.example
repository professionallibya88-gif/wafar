# ⚠️ تحذير أمان مهم ⚠️
# - لا تستخدم هذه القيم في الإنتاج أبداً
# - غيّر جميع كلمات المرور والمفاتيح السرية قبل النشر
# - تأكد من إضافة .env إلى .gitignore
# - استخدم كلمات مرور قوية لا تقل عن 16 حرف

# Server
PORT=5050
NODE_ENV=development

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=libya_spare_parts
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_IN_PRODUCTION

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT - ⚠️ غيّر هذا في الإنتاج ⚠️
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# Session - ⚠️ غيّر هذا في الإنتاج ⚠️
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_IN_PRODUCTION

# Upload (Vercel Blob & Local Fallback)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600
BLOB_READ_WRITE_TOKEN=
USE_VERCEL_BLOB=false

# PDF Processing Method: python_ai | python_pypdf | node_pdf | aws_textract
DEFAULT_PDF_METHOD=python_pypdf

# AWS (for Textract method)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Python Service
PYTHON_SERVICE_URL=http://localhost:5051
PYTHON_SERVICE_PORT=5051
FLASK_DEBUG=false

# Admin - ⚠️ غيّر هذه في الإنتاج ⚠️
ADMIN_PHONE=0910000000
ADMIN_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_IN_PRODUCTION

# Security
ALLOWED_ORIGINS=http://localhost:3050,http://localhost:5050

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
