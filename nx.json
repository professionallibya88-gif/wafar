{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "version": 2,
  "npmScope": "waffer",
  "cli": {
    "defaultCollection": "@nx/workspace"
  },
  "plugins": [
    {
      "plugin": "@nx/workspace",
      "options": {
        "workspaceName": "waffer-platform"
      }
    }
  ],
  "projects": {
    "backend": {
      "root": "apps/backend",
      "sourceRoot": "apps/backend/src"
    },
    "frontend": {
      "root": "apps/frontend",
      "sourceRoot": "apps/frontend/src"
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^default"
      ]
    },
    "test": {
      "inputs": [
        "default",
        "^default"
      ]
    },
    "lint": {
      "inputs": [
        "default",
        "{workspaceRoot}/.eslintrc.js"
      ]
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/.eslintrc.js"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/spec.js",
      "!{projectRoot}/**/*.spec.js",
      "!{projectRoot}/**/*.test.js"
    ]
  },
  "analytics": true
}
